{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Linux Control Center",
  "version": "0.1.0",
  "identifier": "io.github.linux-control-center",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Linux Control Center",
        "width": 960,
        "height": 680,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "linux-control-center",
    "category": "Utility",
    "shortDescription": "Manage Hyprland, Waybar, Rofi and more from one place.",
    "longDescription": "Linux Control Center lets you edit, preview and apply configuration files for Hyprland, Waybar, Rofi and systemd from a single desktop app. Changes are atomic, backed up automatically, and fully reversible via snapshots.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
